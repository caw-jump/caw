  "page_settings": {
    "hide_title": "yes",
    "custom_css": "\n.text-gradient {\n    background: linear-gradient(90deg, #FFD200, #F58220);\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n}\n"
  },
  "version": "0.4",
  "title": "Single Product – Hero + gallery & description",
  "type": "single",
  "document": {
    "settings": {
      "template": "default",
      "page_layout": "elementor_canvas"
