<% const searchHtml = (() => {
  const q = typeof query !== 'undefined' ? query : '';
  const r = typeof results !== 'undefined' ? results : { articles: [], pages: [] };
  const totalResults = (r.articles || []).length + (r.pages || []).length;

  let html = `<section style="background:#050505;padding:6rem 0 2rem">
    <div style="max-width:800px;margin:0 auto;padding:0 1.5rem;text-align:center">
      <span style="display:inline-block;font-family:ui-monospace,monospace;font-size:.85rem;text-transform:uppercase;letter-spacing:.12em;color:#00FF94;margin-bottom:1.5rem;padding:.4rem 1rem;border:1px solid rgba(0,255,148,.3)">SEARCH</span>
      <h1 style="font-size:2.5rem;font-weight:900;color:#fff;margin-bottom:1.5rem;letter-spacing:-2px">Find What<br><span style="color:#00FF94">You Need.</span></h1>
      <form action="/search" method="GET" style="display:flex;gap:.75rem;max-width:600px;margin:0 auto">
        <input type="text" name="q" value="${q.replace(/"/g, '&quot;')}" placeholder="Search articles, services, topics..."
          style="flex:1;background:#111;border:1px solid rgba(255,255,255,.2);color:#fff;padding:.85rem 1.25rem;font-size:1rem;border-radius:.5rem;font-family:ui-monospace,monospace;outline:none"
          onfocus="this.style.borderColor='#00FF94'" onblur="this.style.borderColor='rgba(255,255,255,.2)'" autofocus />
        <button type="submit" style="padding:.85rem 1.75rem;background:#00FF94;color:#050505;font-weight:700;font-size:.9rem;text-transform:uppercase;letter-spacing:.05em;border:none;border-radius:.5rem;cursor:pointer">Search</button>
      </form>
    </div>
  </section>`;

  if (q && totalResults > 0) {
    html += `<section style="background:#050505;padding:2rem 0 4rem"><div style="max-width:800px;margin:0 auto;padding:0 1.5rem">`;
    html += `<p style="font-family:ui-monospace,monospace;font-size:.85rem;color:rgba(255,255,255,.5);margin-bottom:1.5rem">${totalResults} result${totalResults !== 1 ? 's' : ''} for "${q.replace(/</g,'&lt;')}"</p>`;

    if (r.articles.length > 0) {
      html += `<h2 style="font-family:ui-monospace,monospace;font-size:.9rem;color:#00FF94;margin-bottom:1rem;text-transform:uppercase">// Articles</h2>`;
      html += `<div style="display:grid;gap:.75rem;margin-bottom:2rem">`;
      for (const a of r.articles) {
        const date = a.published_at ? new Date(a.published_at).toLocaleDateString('en-US', { year:'numeric', month:'short', day:'numeric' }) : '';
        const tagHtml = (a.tags || []).slice(0,3).map(t => `<span style="font-size:.65rem;padding:.1rem .4rem;border:1px solid rgba(0,255,148,.25);border-radius:.2rem;color:#00FF94;font-family:ui-monospace,monospace">${t}</span>`).join(' ');
        html += `<a href="/blog/${a.slug}" style="display:block;padding:1.25rem;border:1px solid rgba(255,255,255,.08);border-radius:.5rem;transition:border-color .2s,background .2s" onmouseover="this.style.borderColor='rgba(0,255,148,.3)';this.style.background='rgba(0,255,148,.02)'" onmouseout="this.style.borderColor='rgba(255,255,255,.08)';this.style.background='transparent'">
          <div style="display:flex;align-items:center;gap:.6rem;margin-bottom:.35rem"><span style="font-size:.7rem;color:rgba(255,255,255,.4);font-family:ui-monospace,monospace">${date}</span><span style="font-size:.65rem;text-transform:uppercase;color:#00B8FF;font-family:ui-monospace,monospace">${a.category || ''}</span></div>
          <h3 style="font-size:1.05rem;font-weight:700;color:#fff;margin-bottom:.3rem">${a.title}</h3>
          ${a.excerpt ? `<p style="font-size:.8rem;color:rgba(255,255,255,.5);margin-bottom:.5rem">${a.excerpt}</p>` : ''}
          <div style="display:flex;gap:.35rem;flex-wrap:wrap">${tagHtml}</div>
        </a>`;
      }
      html += `</div>`;
    }

    if (r.pages.length > 0) {
      html += `<h2 style="font-family:ui-monospace,monospace;font-size:.9rem;color:#00B8FF;margin-bottom:1rem;text-transform:uppercase">// Pages</h2>`;
      html += `<div style="display:grid;gap:.5rem;margin-bottom:2rem">`;
      for (const p of r.pages) {
        const path = p.slug ? '/' + p.slug : '/';
        html += `<a href="${path}" style="display:flex;align-items:center;gap:.75rem;padding:.85rem 1rem;border:1px solid rgba(255,255,255,.06);border-radius:.375rem;transition:border-color .2s" onmouseover="this.style.borderColor='rgba(0,184,255,.3)'" onmouseout="this.style.borderColor='rgba(255,255,255,.06)'">
          <span style="color:#00B8FF;font-family:ui-monospace,monospace;font-size:.75rem">${path}</span>
          <span style="color:#fff;font-size:.9rem">${p.title}</span>
        </a>`;
      }
      html += `</div>`;
    }

    html += `</div></section>`;
  } else if (q) {
    html += `<section style="background:#050505;padding:2rem 0 4rem"><div style="max-width:800px;margin:0 auto;padding:0 1.5rem;text-align:center">
      <p style="color:rgba(255,255,255,.5);font-family:ui-monospace,monospace;margin-bottom:1rem">No results for "${q.replace(/</g,'&lt;')}"</p>
      <p style="color:rgba(255,255,255,.35);font-size:.875rem">Try different keywords or <a href="/blog" style="color:#00FF94">browse all articles</a></p>
    </div></section>`;
  }

  return html;
})(); %>
<%- include('layout', { body: searchHtml, title, description, siteName, nav, footer, palette, currentPath }) %>
